{
  "_meta": {
    "description": "BookingScraper Pro — Language configuration. Single source of truth for ALL language-dependent dictionaries.",
    "version": "1.0",
    "build": 98,
    "doc": [
      "To add a new language (e.g. 'ru'), add its code to ENABLED_LANGUAGES in .env",
      "and complete ALL sections below for that language.",
      "The startup validator (LanguageConfigValidator) will BLOCK startup if any",
      "required section is missing for an enabled language.",
      "",
      "Supported alphabet ranges: Latin, Cyrillic, CJK (Chinese/Japanese/Korean),",
      "Arabic, Hebrew, Thai, and any other UTF-8 encoded script.",
      "",
      "Section 'room_level_category_labels':",
      "  Use '__EXCLUDED__' as value when the label collides with hotel-level",
      "  facility labels (e.g. FR 'Equipements'). The validator treats this",
      "  as an intentional exclusion, not a missing entry.",
      "",
      "Section 'category_key_map':",
      "  Organized as { api_key: { lang: [text_variants_lowercase] } }.",
      "  All text variants must be lowercase. Multiple variants per lang allowed.",
      "",
      "Section 'facility_group_map':",
      "  Keys are Booking.com groupId values (as strings).",
      "  groupId=15 is 'Room Amenities' (used in BUG-SVC-002-FIX filter).",
      "",
      "Section 'service_category_rules':",
      "  Keyword-based inference rules for services without DOM category groups.",
      "  'keywords' is a flat list of lowercase terms across all languages.",
      "  'group_id' references a key in 'facility_group_map'.",
      "",
      "Section 'see_all_patterns':",
      "  Regex fragments for 'See all N facilities' noise-text detection.",
      "  Each entry is a raw regex string that will be ORed together."
    ]
  },

