# BookingScraper Pro — .gitignore

# Python
__pycache__/
*.py[cod]
*.pyd
*.pyo
.Python
*.egg
*.egg-info/
dist/
build/
.eggs/
*.so
*.dylib

# Virtual environments
.venv/
venv/
env/
ENV/

# Environment & Secrets — NEVER COMMIT
.env
*.env
!.env.example

# Database
*.db
*.sqlite3
celerybeat-schedule.db
celerybeat.pid

# Logs
logs/
*.log
*.log.*

# Debug HTML (may contain hotel page content)
debug_html/

# Images (large binary files)
images/

# Exports
exports/

# IDE
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/

# Alembic — do not ignore revision files
# migrations/versions/*.py  ← keep these

# Windows
desktop.ini
$RECYCLE.BIN/
