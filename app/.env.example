# =============================================================================
# BookingScraper Pro v6.0 — Environment Configuration Template
# Version: v36 (Enterprise Audit Applied 2026-03-06)
# Windows 11 Local Deployment
#
# INSTRUCTIONS:
#   1. Copy this file to .env:    copy .env.example .env
#   2. Fill in ALL values marked  <REQUIRED>
#   3. Review optional settings   (have sensible defaults)
#   4. NEVER commit .env to Git   (already in .gitignore)
#
# .env is parsed by python-dotenv (app/database.py, app/config.py).
# =============================================================================


# ─── APPLICATION ──────────────────────────────────────────────────────────────

# API key to protect administrative endpoints (/scraping/force-now, /urls/reset, etc.)
# Set a strong random value in production: python -c "import secrets; print(secrets.token_hex(32))"
# Empty string = no protection (development only)
API_KEY=                              # <REQUIRED for production>

APP_NAME=Booking Scraper Pro
APP_VERSION=6.0.0
DEBUG=False


# ─── POSTGRESQL ───────────────────────────────────────────────────────────────

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres                      # or scraper_app (least privilege)
DB_PASSWORD=                          # <REQUIRED> — never empty
DB_NAME=booking_scraper

# Connection pool tuning (Windows 11 local deployment defaults)
DB_POOL_SIZE=5                        # Base connections in pool
DB_MAX_OVERFLOW=2                     # Extra connections above pool_size
DB_POOL_TIMEOUT=30                    # Seconds to wait for a connection
DB_POOL_RECYCLE=1800                  # Recycle connections after 30 min
DB_TOTAL_HARD_CAP=20                  # Hard cap: pool_size + max_overflow must be <=

# Query timeouts (milliseconds)
STMT_TIMEOUT_OLTP_MS=30000            # 30s for regular queries
# STMT_TIMEOUT_OLAP_MS=300000         # 300s for aggregation queries (optional)


# ─── REDIS / MEMURAI ──────────────────────────────────────────────────────────
# Memurai is the recommended Redis-compatible server for Windows 11.
# Download: https://www.memurai.com/get-memurai

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=                       # Leave empty if no Redis auth configured


# ─── CELERY ───────────────────────────────────────────────────────────────────

CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_WORKER_CONCURRENCY=1           # MUST be 1 on Windows (solo pool)

# Celery task time limits (seconds)
CELERY_TASK_SOFT_TIME_LIMIT=150       # Graceful abort signal
CELERY_TASK_TIME_LIMIT=180            # Hard kill after this


# ─── VPN (NordVPN) ────────────────────────────────────────────────────────────

VPN_ENABLED=False                     # Set True to enable NordVPN rotation
# Priority order: UK first for en-gb scraping, then fallback chain
VPN_COUNTRIES=UK,US,CA,DE,FR,NL,IT,ES
VPN_ROTATION_INTERVAL=50
VPN_ROTATE_EVERY_N=10                 # Rotate after N hotels
VPN_FAILOVER_TIMEOUT_SECS=90          # Total failover timeout

# Circuit breaker
VPN_FAILURE_THRESHOLD=5               # Open circuit after N consecutive failures
VPN_COOLDOWN_SECONDS=300              # Circuit cooldown: 5 minutes


# ─── SCRAPING BEHAVIOUR ───────────────────────────────────────────────────────

# Languages to scrape per hotel URL (ISO 639-1 codes, comma-separated)
# Must match Booking.com supported locales
LANGUAGES_ENABLED=en,es,de,fr,it
DEFAULT_LANGUAGE=en

HEADLESS_BROWSER=True
BROWSER_TIMEOUT=30
PAGE_LOAD_WAIT=5
SCROLL_ITERATIONS=3
MAX_RETRIES=3
RETRY_DELAY=60                        # Seconds between retries
MIN_REQUEST_DELAY=2.0
MAX_REQUEST_DELAY=5.0
USE_SELENIUM=False                    # True = Selenium (JS); False = CloudScraper (faster)

# Worker count (MUST be 1 when VPN_ENABLED=True)
SCRAPER_MAX_WORKERS=1
WATCHDOG_INTERVAL_SECS=120

# Batch dispatch settings
BATCH_SIZE=5
MAX_CONCURRENT_TASKS=3


# ─── FILE PATHS ───────────────────────────────────────────────────────────────
# Defaults to <repo_root>/data — change only if you need a specific location
# Use forward slashes or double backslashes on Windows:
# BASE_DATA_PATH=C:\\BookingScraper\\data
# BASE_DATA_PATH=C:/BookingScraper/data

# BASE_DATA_PATH=
# IMAGES_PATH=
# EXPORTS_PATH=
# LOGS_PATH=


# ─── IMAGES ───────────────────────────────────────────────────────────────────

DOWNLOAD_IMAGES=True
IMAGE_QUALITY=85
IMAGE_MAX_WIDTH=1920
IMAGE_MAX_HEIGHT=1080
MAX_IMAGE_WORKERS=5


# ─── DISPATCHER ───────────────────────────────────────────────────────────────

USE_CELERY_DISPATCHER=False           # True = Celery Beat; False = asyncio auto-dispatch


# ─── CSV UPLOAD LIMITS ────────────────────────────────────────────────────────

CSV_MAX_FILE_MB=10                    # Maximum upload size in MB
CSV_MAX_ROWS=50000                    # Maximum rows per CSV file


# ─── CONCURRENCY TUNING ───────────────────────────────────────────────────────

# [FIX ERR-CONC-001] URLs stuck in 'processing' for more than N minutes are reset
STALE_PROCESSING_MINUTES=30

# [FIX CRIT-007] Lock timeout for completeness_service INSERT operations (ms)
COMPLETENESS_LOCK_TIMEOUT_MS=5000


# ─── DEBUG HTML FILES ─────────────────────────────────────────────────────────

# [FIX CRIT-007] Debug HTML cleanup policy
DEBUG_HTML_MAX_AGE_HOURS=24           # Delete debug HTMLs older than N hours
DEBUG_HTML_MAX_TOTAL_MB=500           # Evict oldest when total exceeds N MB


# ─── ERROR HANDLING ───────────────────────────────────────────────────────────

# [FIX HIGH-005] Centralized error message truncation (must match DB VARCHAR(2000))
MAX_ERROR_LEN=2000


# ─── BROWSER PATHS (optional — auto-detected if empty) ───────────────────────
# Set these if browser auto-detection fails on your machine
# BROWSER_BRAVE_PATH=C:\Program Files\BraveSoftware\Brave-Browser\Application\brave.exe
# BROWSER_CHROME_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
# BROWSER_EDGE_PATH=C:\Program Files (x86)\Microsoft\Edge\Application\msedge.exe
# BROWSER_OPERA_PATH=C:\Users\YourName\AppData\Local\Programs\Opera\opera.exe


# ─── LOGGING ──────────────────────────────────────────────────────────────────

LOG_LEVEL=INFO
# Set LOG_JSON=True to enable machine-parseable JSON logs (ELK/Splunk)
# LOG_JSON=False


# ─── EXPORT FORMATS ───────────────────────────────────────────────────────────

# Supported: csv, json, excel (comma-separated)
EXPORT_FORMATS=csv,json,excel


# =============================================================================
# QUICK START CHECKLIST
# =============================================================================
# [ ] 1. PostgreSQL running locally (port 5432)
# [ ] 2. DB_PASSWORD set to your postgres password
# [ ] 3. Memurai/Redis running (port 6379) — optional, enables Celery
# [ ] 4. API_KEY set to a random string (production only)
# [ ] 5. Run: psql -U postgres -f sql/install_clean_v31.sql
# [ ] 6. Run: python -m uvicorn app.main:app --reload --port 8000
# [ ] 7. Browse to: http://localhost:8000/docs
# =============================================================================
