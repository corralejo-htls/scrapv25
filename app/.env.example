# =============================================================================
# BookingScraper Pro v6.0 — Environment Configuration Template
# Windows 11 Local Deployment
# Version: v40 (2026-03-06)
#
# INSTRUCTIONS:
#   1. Copy this file to .env in the project root:
#        copy .env.example .env       (Windows CMD)
#        cp .env.example .env         (PowerShell / bash)
#   2. Fill in ALL required values (marked with REQUIRED).
#   3. Review optional values and adjust for your environment.
#   4. NEVER commit .env to version control (it is in .gitignore).
# =============================================================================

# ── POSTGRESQL (REQUIRED) ─────────────────────────────────────────────────────
# PostgreSQL must be installed and running locally.
# Default port: 5432. Default user: postgres.
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
# REQUIRED: Set your PostgreSQL password. No default — app will refuse to start.
DB_PASSWORD=your_postgres_password_here
DB_NAME=booking_scraper

# ── REDIS / MEMURAI (REQUIRED for Celery task queue) ──────────────────────────
# Install Memurai (Windows Redis port) from https://www.memurai.com/
# or use Redis for Windows from https://github.com/microsoftarchive/redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# Optional: only if Redis requires authentication
REDIS_PASSWORD=

# Celery broker/backend (derived from Redis settings above)
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_WORKER_CONCURRENCY=1

# ── APPLICATION ────────────────────────────────────────────────────────────────
DEBUG=false
# API key to protect critical endpoints (e.g. /scraping/force-now).
# Empty = no protection (development only). Set a strong value in production.
API_KEY=

# ── SCRAPING ───────────────────────────────────────────────────────────────────
# false = use cloudscraper (faster, no browser needed)
# true  = use Selenium (for JS-heavy pages, requires browser installed)
USE_SELENIUM=false
HEADLESS_BROWSER=true
BROWSER_TIMEOUT=30
PAGE_LOAD_WAIT=5
MAX_RETRIES=3
RETRY_DELAY=60
MIN_REQUEST_DELAY=2.0
MAX_REQUEST_DELAY=5.0
# Number of parallel scraping workers. Keep at 1 unless VPN_ENABLED=false.
SCRAPER_MAX_WORKERS=1

# ── LANGUAGES ──────────────────────────────────────────────────────────────────
# Comma-separated ISO 639-1 language codes. All must be valid codes.
LANGUAGES_ENABLED=en,es,de,fr,it
DEFAULT_LANGUAGE=en

# ── VPN (OPTIONAL) ─────────────────────────────────────────────────────────────
VPN_ENABLED=false
# Country rotation order (NordVPN country codes)
VPN_COUNTRIES=UK,US,CA,DE,FR,NL,IT,ES
VPN_ROTATION_INTERVAL=50
VPN_ROTATE_EVERY_N=10
VPN_FAILOVER_TIMEOUT_SECS=90

# ── BROWSER PATHS (leave empty to use auto-detection) ──────────────────────────
# Example: BROWSER_BRAVE_PATH=C:\Program Files\BraveSoftware\Brave-Browser\Application\brave.exe
BROWSER_BRAVE_PATH=
BROWSER_OPERA_PATH=
BROWSER_CHROME_PATH=
BROWSER_EDGE_PATH=

# ── IMAGES ─────────────────────────────────────────────────────────────────────
DOWNLOAD_IMAGES=true
IMAGE_QUALITY=85
IMAGE_MAX_WIDTH=1920
IMAGE_MAX_HEIGHT=1080
MAX_IMAGE_WORKERS=5

# ── DATA PATHS (defaults to <project_root>/data — change only if needed) ────────
# Windows example: BASE_DATA_PATH=C:\BookingScraper\data
# BASE_DATA_PATH=
# IMAGES_PATH=
# EXPORTS_PATH=
# LOGS_PATH=

# ── DATABASE POOL ──────────────────────────────────────────────────────────────
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=5
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
STMT_TIMEOUT_OLTP_MS=30000
STMT_TIMEOUT_OLAP_MS=300000

# ── LOGGING ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── MONITORING ─────────────────────────────────────────────────────────────────
SLOW_QUERY_THRESHOLD_MS=2000
COMPLETENESS_LOCK_TIMEOUT_MS=5000
STALE_PROCESSING_MINUTES=30

# ── RATE LIMITING ──────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=120

# ── CELERY TASK TIMEOUTS ───────────────────────────────────────────────────────
CELERY_TASK_SOFT_TIME_LIMIT=150
CELERY_TASK_TIME_LIMIT=180
