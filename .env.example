# BookingScraper Pro v6.0 — Environment Configuration
# =====================================================
# BUG-003 FIX: This file belongs at PROJECT ROOT (not app/)
# Usage: copy .env.example .env   (Windows CMD)
#        Copy-Item .env.example .env   (PowerShell)
#
# BUG-001 FIX: DB_USER and DB_PASSWORD are validated at module import time.
#              Leaving them empty causes EnvironmentError at startup.

# =============================================================================
# APPLICATION  (BUG-008 FIX: version is 6.0.0 everywhere)
# =============================================================================
APP_ENV=development
APP_VERSION=6.0.0
APP_HOST=127.0.0.1
APP_PORT=8000

# =============================================================================
# DATABASE
# =============================================================================
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bookingscraper
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=5
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600
DB_ECHO=false

# =============================================================================
# REDIS / MEMURAI
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# =============================================================================
# SCRAPER
# BUG-004: VPN_ENABLED=true requires SCRAPER_MAX_WORKERS=1
# =============================================================================
SCRAPER_MAX_WORKERS=4
SCRAPER_ENGINE=cloudscraper
SCRAPER_REQUEST_DELAY_MIN=2.0
SCRAPER_REQUEST_DELAY_MAX=8.0
SCRAPER_PAGE_TIMEOUT=30
SCRAPER_MAX_RETRIES=3
ENABLED_LANGUAGES_STR=en,es,de,fr,it

# BUG-022 FIX: was hardcoded=1 in completeness_service.py
MAX_LANG_RETRIES=3

# =============================================================================
# VPN
# =============================================================================
VPN_ENABLED=false
VPN_ROTATION_INTERVAL=600
VPN_CONNECT_TIMEOUT=30
VPN_COUNTRIES_STR=

# =============================================================================
# IMAGES
# =============================================================================
IMAGES_DIR=C:/BookingScraper/images
IMAGES_MAX_WORKERS=4
IMAGES_TIMEOUT=30
IMAGES_MAX_SIZE_MB=10

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=INFO
LOG_DIR=./logs
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# =============================================================================
# PATHS
# =============================================================================
DATA_DIR=C:/BookingScraper/data
EXPORT_DIR=C:/BookingScraper/exports
DEBUG_HTML_DIR=C:/BookingScraper/debug

# =============================================================================
# SECURITY
# =============================================================================
SECRET_KEY=change-this-to-a-random-secret-key
API_KEY=
ALLOWED_HOSTS=localhost,127.0.0.1
