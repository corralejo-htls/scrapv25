# ============================================================================
# .env.example — BookingScraper Pro v6.0.0 Build 120
# APLICADO EN: C:\BookingScraper\.env
# Copia este archivo a .env y rellena tus valores reales.
# NUNCA subas .env al control de versiones (.gitignore lo excluye).
#
# ── Historial de variables de configuración (Build 63 → 120) ────────────────
#
# BUILD 120: SIN NUEVAS VARIABLES DE ENTORNO.
#   BUG-DISPATCH-001-FIX: SCRAPER_BATCH_SIZE ya documentado abajo.
#   BUG-LOCK-TTL-001-FIX: LOCK_TTL se deriva de TASK_WATCHDOG_TIMEOUT_S+60 (sin var nueva).
#   SEC-UI-001-FIX: /export/ui y /export/languages ahora requieren Bearer token
#     cuando REQUIRE_API_KEY=True. No hay nueva variable de entorno.
#
# BUILD 119: SIN NUEVAS VARIABLES DE ENTORNO.
#   BUG-CHROMEDRIVER-002-FIX: CHROMEDRIVER_PATH ahora comentado por defecto.
#     Activar webdriver-manager (detecta versión Brave automáticamente).
#     Sólo descomentar CHROMEDRIVER_PATH para entornos offline o versión fija.
#
# BUILD 116: NUEVAS VARIABLES (NAV-TIMEOUT-001-FIX / BUG-DNS-RACE-001-FIX)
#   NAVIGATION_TIMEOUT_S      ← nueva. Timeout daemon thread para driver.get(url).
#                               Bloqueo indefinido confirmado en INC-2026-0602-BROWSER-FREEZE-001.
#   VPN_DNS_STABILIZE_DELAY_S ← nueva. Delay post-conexión VPN para estabilizar DNS.
#                               Evidencia: 6 NameResolutionError cf.bstatic.com en incidente.
#   GALLERY_MODAL_SCROLL_ITERATIONS ← VALOR CORREGIDO: 8 → 16.
#                               Mitiga BUG-GALLERY-MISMATCH-001 (captura 50% del badge).
#
# BUILD 115: NUEVAS VARIABLES (BUG-BROWSER-RESTART-HANG-001 / BUG-BROWSER-LAUNCH-HANG-001)
#   BROWSER_QUIT_TIMEOUT_S   ← nueva. Timeout para driver.quit() via daemon thread.
#   BROWSER_LAUNCH_TIMEOUT_S ← nueva. Timeout para webdriver.Chrome() via daemon thread.
#
# BUILD 114: NUEVAS VARIABLES (BUG-VPN-HANG-001 / BUG-TASK-HANG-001 / CFG-VPN-INTERVAL-001)
#   VPN_SUBPROCESS_TIMEOUT_S ← nueva. Timeout nordvpn.exe subprocess.
#   VPN_ROTATE_TIMEOUT_S     ← nueva. Timeout operación completa de rotación VPN.
#   TASK_WATCHDOG_TIMEOUT_S  ← nueva. Watchdog threading.Timer para Celery pool=solo.
#   VPN_ROTATION_INTERVAL    ← VALOR CORREGIDO: 50 → 120.
#                              50s era demasiado agresivo con 2 hilos simultáneos.
#
# BUILD 113: NUEVA VARIABLE (BUG-VPN-POPUP-DIRECT-001-FIX)
#   VPN_ROTATE_SKIP_DISCONNECT ← nueva. True = nordvpn -c directo (sin -d previo).
#                                Elimina popup «¿Pausar la conexión automática?».
#
# BUILD 112: NUEVA VARIABLE (BUG-ONLYTITLE-001)
#   API_EXPORT_ONLY_TITLE    ← nueva. Default False = exportación completa de campos.
#                              True solo para pruebas de conexión inicial con la API.
#
# BUILD 111: NUEVA VARIABLE (BUG-SVC-POPULAR-CAT-001)
#   SVC_POPULAR_FALLBACK_CATEGORY_ENABLED ← nueva. Extrae categoría del bloque
#                              «most popular facilities» cuando facility-group falla.
#
# BUILD 110: NUEVAS VARIABLES (BUG-GALLERY-MODAL-001)
#   GALLERY_MODAL_DISMISS_CONSENT ← nueva. Descarta overlay OneTrust antes de abrir modal.
#   GALLERY_MODAL_OPEN_RETRIES    ← nueva. Reintentos de apertura del modal de galería.
#   API_IMAGES_STRICT_GALLERY     ← nueva. Si True: images[] vacío cuando falla modal.
#
# BUILD 109: NUEVAS VARIABLES (BUG-IMG-CLASS-001)
#   IMAGE_CLASSIFICATION_ENABLED  ← nueva. Activa clasificación galería vs no-galería.
#   API_IMAGES_GALLERY_ONLY       ← nueva. Solo fotos gallery_visible en el payload API.
#   GALLERY_MODAL_TIMEOUT_S       ← nueva. Timeout espera del modal de galería.
#   GALLERY_MODAL_SCROLL_ITERATIONS ← nueva. Iteraciones de scroll dentro del modal.
#   GALLERY_MODAL_SCROLL_PAUSE_S  ← nueva. Pausa entre scrolls del modal.
#
# BUILD 74: ⚠ SIN CAMBIOS EN VARIABLES.
#   Eliminado --user-data-dir=data/brave_profile. Brave usa su perfil normal.
#   Resuelve DevToolsActivePort. Simplifica código.
#
# BUILD 70: NUEVA VARIABLE.
#   SELENIUM_BRAVE_PROFILE_DIR ← nueva (perfil Brave aislado para Selenium).
#   BUILD 74: deshabilitado — comentado, Brave usa perfil del sistema.
#
# BUILD 68: BUG-VPN-001 fix. ⚠ SIN CAMBIOS EN VARIABLES.
#
# BUILD 64: BUG-DATA-001 + BUG-PERF-001 fixes.
#   SELENIUM_CONTENT_WAIT_TIMEOUT_S ← nueva.
#   LANG_SCRAPE_DELAY_IT            ← nueva.
#
# BUILD 63: cloudscraper eliminado. Selenium es el único motor.
#   ⚠ SIN CAMBIOS EN VARIABLES.
# ============================================================================


# ── Seguridad ─────────────────────────────────────────────────────────────────
# Para regenerar SECRET_KEY:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=Generate-new-KEY
API_KEY=
REQUIRE_API_KEY=false


# ── External API export (Build 91) ────────────────────────────────────────────
# Credenciales para exportar datos scrapeados a la API externa de hoteles.
# Ver: POST /export/send  y  POST /export/send/{url_id}
# Regla: 'en' siempre primero en EXT_API_DEFAULT_LANGUAGES; nunca omitirlo.
# Dejar EXT_API_DEFAULT_LANGUAGES vacío = usa ENABLED_LANGUAGES automáticamente.
## EXT_API_BASE_URL=https://sofia.hotel-com.com/api
EXT_API_BASE_URL=https://juliette.com-hotel.com/api
EXT_API_KEY=Generate-new-KEY
EXT_API_DEFAULT_LANGUAGES=

# BUG-ONLYTITLE-001-FIX (Build 112): control del flag onlyTitle en API.
# Si True, la API externa procesa SOLO el campo name/title (silencia los 20
# campos restantes de data[]). Default False = producción completa.
# Usar True ÚNICAMENTE para pruebas de conexión inicial con la API externa.
# Rango válido: true | false | Recomendado: false
API_EXPORT_ONLY_TITLE=false


# ── Base de datos ─────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bookingscraper
DB_USER=Generate-new-KEY-USER
DB_PASSWORD=Generate-new-KEY-DB

# Pool de conexiones (Windows 11: max_connections=50-100 en postgresql.conf)
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=5
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600


# ── Redis / Memurai ───────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=20
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1


# ── Scraper — Build 63: parámetros aplican a Selenium (CloudScraper eliminado) ─
SCRAPER_MAX_WORKERS=2
# BUG-DISPATCH-001-FIX (Build 120): URLs fetched per Beat tick.
# Previously hardcoded to SCRAPER_MAX_WORKERS. Increase this value to process
# more URLs per batch cycle. Ensure TASK_WATCHDOG_TIMEOUT_S > SCRAPER_BATCH_SIZE × 250.
# Example: SCRAPER_BATCH_SIZE=20 processes 20 URLs before releasing the lock.
SCRAPER_BATCH_SIZE=2
SCRAPER_REQUEST_TIMEOUT=30
SCRAPER_RETRY_DELAY=2.0
MAX_RETRIES=3
MAX_LANG_RETRIES=3


# ── BUG-LANG-001-FIX: Anti-bot / delays entre idiomas ────────────────────────
# Delay base (segundos) entre idiomas consecutivos para el mismo URL.
# Simula lectura humana entre páginas. Reduce detección de bot por Booking.com.
# Rango válido: 0.0 - 120.0  |  Recomendado: 10.0
LANG_SCRAPE_DELAY=10.0

# Jitter aleatorio (0..N segundos) sumado al delay base.
# Evita patrones de request predecibles que activan rate-limiting.
# Rango válido: 0.0 - 30.0  |  Recomendado: 5.0
LANG_SCRAPE_JITTER=5.0

# Rota VPN tras el PRIMER fallo de idioma (ip_known_blocked activo desde v1).
# Rango válido: 1 - 6 | Recomendado: 1
MAX_CONSECUTIVE_LANG_FAILURES=1

# Umbral en bytes para detectar páginas de bloqueo Cloudflare.
# Páginas reales de Booking.com: 150.000-500.000 bytes.
# Respuesta < SHORT_HTML_THRESHOLD → challenge page → return None inmediato.
# Rango válido: 1000 - 20000  |  Recomendado: 5000
SHORT_HTML_THRESHOLD=5000


# ── BUG-PERF-001-FIX: Rendimiento idioma italiano (Build 64) ─────────────────
# Tiempo de espera por selector CSS en el bucle de verificación de contenido.
# Con EC.any_of() (Build 98): peor caso = 1 × este valor = 10 s.
# Rango válido: 2.0 - 60.0 | Recomendado: 10.0
SELENIUM_CONTENT_WAIT_TIMEOUT_S=10.0

# Delay adicional (segundos) aplicado SOLO al pase del idioma italiano.
# Italian avg 73,7 s vs 49-64 s para otros idiomas (15,4% outliers > 120 s).
# Rango válido: 0.0 - 60.0 | Recomendado: 5.0 | 0.0 para deshabilitar
LANG_SCRAPE_DELAY_IT=5.0


# ── BUG-BROWSER-RESTART-HANG-001-FIX / BUG-BROWSER-LAUNCH-HANG-001-FIX (Build 115) ──
# En Windows 11, driver.quit() y webdriver.Chrome() pueden bloquearse
# indefinidamente si Brave está congelado en una página de desafío JavaScript
# (chal_t=, force_referer=). Sin timeout, self._lock queda retenido para siempre.
# Incidente confirmado: 2026-06-02 16:02:55 — worker muerto — 2h46m sin scraping.
#
# Timeout (s) para driver.quit() — daemon thread con join + psutil force-kill.
# Rango válido: 5 - 120 | Recomendado: 30
BROWSER_QUIT_TIMEOUT_S=30

# Timeout (s) para webdriver.Chrome() — daemon thread con join.
# Fallo limpio: el idioma se marca fallido y se reintenta en el siguiente batch.
# Rango válido: 10 - 300 | Recomendado: 60
BROWSER_LAUNCH_TIMEOUT_S=60


# ── BUG-VPN-HANG-001-FIX (Build 114) — timeouts subprocess NordVPN ───────────
# Incidente INC-2026-0602-RADISSON-001: worker congelado 6 horas por pipes
# de subprocess heredados por procesos hijo de nordvpn.exe en Windows 11.
#
# Timeout (s) para llamadas subprocess a nordvpn.exe (daemon thread).
# Rango válido: 10 - 120 | Recomendado: 45
VPN_SUBPROCESS_TIMEOUT_S=45

# Timeout (s) para la operación completa de rotación VPN.
# Si rotate() no completa, el loop continúa sin rotación.
# Rango válido: 20 - 300 | Recomendado: 90
VPN_ROTATE_TIMEOUT_S=90

# ── BUG-TASK-HANG-001-FIX (Build 114) — watchdog Celery Windows ──────────────
# Celery time_limit/soft_time_limit son NO-OP en Windows 11 con pool=solo.
# Fix: threading.Timer watchdog. Si la tarea no completa, os._exit(1) mata el worker.
# start_celery.bat (Build 115) lo reinicia automáticamente si exit code != 0.
# Rango válido: 60 - 7200 | Recomendado: 600
TASK_WATCHDOG_TIMEOUT_S=600


# ── BUG-LANG-002-FIX: Selenium language mismatch (Build 62) ──────────────────
# Inyectar Accept-Language correcto vía CDP y borrar cookies antes de cada carga.
SELENIUM_RESET_LANG_ON_EACH_REQUEST=true

# Reiniciar el browser Selenium completo tras cada rotación forzada de VPN.
# Garantiza perfil limpio: sin DNS cacheado, sin sesiones TLS reusadas.
SELENIUM_RESTART_AFTER_VPN_ROTATE=true

# Segundos de espera para verificar el idioma de la página tras carga.
SELENIUM_LANG_VERIFY_TIMEOUT_S=5.0

# ── BUG-VPN-006-FIX / BUG-VPN-007-FIX: Perfil Brave aislado (Build 70-71) ───
# BUILD 74: deshabilitado — Brave usa perfil del sistema (comportamiento original).
# Dejar comentado o vacío. Descomentar solo si reaparecen tabs nordaccount.com.
# Ruta relativa al proyecto: Recomendado data/brave_profile
# SELENIUM_BRAVE_PROFILE_DIR=


# ── VPN — NordVPN v7.57.4.0 ───────────────────────────────────────────────────
VPN_ENABLED=true
VPN_COUNTRIES=Spain,Germany,France,Netherlands,Italy,United_Kingdom,Canada,Sweden

# Intervalo mínimo (s) entre rotaciones rutinarias de VPN.
# CFG-VPN-INTERVAL-001 (Build 114): CORREGIDO de 50 → 120.
# 50s era demasiado agresivo con 2 hilos simultáneos.
# Rotaciones forzadas por ip_known_blocked NO respetan este umbral.
# Rango válido: 10 - 600 | Recomendado: 120
VPN_ROTATION_INTERVAL=120

# BUG-VPN-POPUP-DIRECT-001-FIX (Build 113).
# True = nordvpn -c directo (sin -d previo). Elimina popup auto-conexión.
# False = legacy (disconnect + connect). Para entornos sin auto-connect.
# Rango válido: true | false | Recomendado: true
VPN_ROTATE_SKIP_DISCONNECT=true


# ── NAV-TIMEOUT-001-FIX (Build 116) — timeout para driver.get(url) ───────────
# Booking.com/Cloudflare pueden servir páginas de desafío que cargan
# inmediatamente pero entran en loops JS infinitos. Sin timeout en driver.get(),
# el navegador queda bloqueado indefinidamente (confirmado INC-2026-0602-BROWSER-FREEZE-001).
# El mecanismo anterior (driver.set_page_load_timeout=30s) NO protege contra
# páginas que cargan rápido y luego ejecutan JS bloqueante.
#
# Timeout (s) para driver.get(url) — daemon thread con join + window.stop().
# En timeout, el idioma falla limpiamente y se reintenta en el siguiente batch.
# Rango válido: 10 - 120 | Recomendado: 45
NAVIGATION_TIMEOUT_S=45


# ── BUG-DNS-RACE-001-FIX (Build 116) — estabilización DNS post-VPN ───────────
# NordVPN reporta "Connected" antes de que el routing DNS del SO esté actualizado.
# Las consultas DNS en los primeros ~2-3s tras la conexión VPN pueden resolver
# contra la interfaz anterior. Evidencia: 6 fallos NameResolutionError para
# cf.bstatic.com en INC-2026-0602-BROWSER-FREEZE-001 (L2843-2845, VPN→Netherlands).
#
# Segundos de espera adicional tras rotate() exitoso, antes de peticiones de red.
# Valor 0.0 deshabilita el delay (no recomendado si VPN_ENABLED=true).
# Rango válido: 0.0 - 30.0 | Recomendado: 5.0
VPN_DNS_STABILIZE_DELAY_S=5.0

# ── BUG-VPN-001-FIX (Build 118) — Circuit Breaker VPN ────────────────────────
# Controla cómo se trata un resultado "Unknown" del servicio de verificación IP
# (api.ipify.org, etc.) cuando el CLI de NordVPN SÍ confirmó la conexión.
#
# True (recomendado): Unknown se trata como ÉXITO → circuit breaker NO se
#   incrementa. Se loguea WARNING. Evita el lockout del CB de Build 115 donde
#   3 timeouts DNS de api.ipify.org (lentitud post-VPN-connect) dispararon
#   record_failure() x3 aunque NordVPN había conectado correctamente.
# False (legacy, Build 115 y anteriores): Unknown se trata como FALLO →
#   record_failure() → comportamiento anterior. Solo si los servicios de
#   verificación IP son siempre fiables en tu entorno.
# Rango válido: true | false | Recomendado: true
VPN_CB_UNKNOWN_IP_AS_SUCCESS=true

# Segundos de cooldown del circuit breaker VPN antes de auto-cerrarse.
# Antes hardcodeado a 300s. Ahora configurable sin modificar código.
# Valor menor (ej. 60s): recuperación más rápida tras fallos transitorios.
# Valor mayor (ej. 600s): más protección ante tormentas de errores VPN.
# Rango válido: 10 - 3600 | Recomendado: 300
VPN_CB_COOLDOWN_S=300


# Extrae la cabecera <h3> VERBATIM del bloque most-popular-facilities (Strategy 4)
# como service_category cuando facility-group-container no encuentra nada.
# Reduce el 0,77% de service_category vacías. Sin inferencia ni traducción.
# Rango válido: true | false | Recomendado: true
SVC_POPULAR_FALLBACK_CATEGORY_ENABLED=true


# ── BUILD 109 — Clasificación de imágenes (BUG-IMG-CLASS-001) ────────────────
# Distingue fotos VISIBLES en la galería pública (exportables a la API) del
# inventario interno (room/facility/exterior), que se descarga pero NO se exporta.

# Activa la captura del modal de galería + clasificación en el pase EN.
# Rango válido: true | false | Recomendado: true
IMAGE_CLASSIFICATION_ENABLED=true

# Si true, el payload images[] incluye SOLO fotos gallery_visible=TRUE.
# Red de seguridad: si falla el modal, recae en todas las descargas 'done'.
# Rango válido: true | false | Recomendado: true
API_IMAGES_GALLERY_ONLY=true

# Timeout (s) de espera del wrapper del modal de galería tras hacer clic.
# Rango válido: 5.0 - 120.0 | Recomendado: 25.0
GALLERY_MODAL_TIMEOUT_S=25.0

# Iteraciones de scroll dentro del modal (8 × 1.5 s = 12 s mínimo).
# Aumentar a 12-15 si el badge del hero muestra > 44 fotos y mismatch > 50%.
# Rango válido: 1 - 40 | Recomendado: 8
GALLERY_MODAL_SCROLL_ITERATIONS=16

# Pausa (s) entre iteraciones de scroll del modal.
# Rango válido: 0.2 - 10.0 | Recomendado: 1.5
GALLERY_MODAL_SCROLL_PAUSE_S=1.5

# ── Build 110 (BUG-GALLERY-MODAL-001) — robustez de apertura del modal ───────
# Antes de abrir el modal: scroll top + ESC + descarte overlay OneTrust.
# Causa principal del 35.7% de hoteles sin galería capturada en Build 109.
# Rango válido: true | false | Recomendado: true
GALLERY_MODAL_DISMISS_CONSENT=true

# Reintentos de apertura del modal antes de degradar a 'sin galería'.
# Rango válido: 1 - 8 | Recomendado: 3
GALLERY_MODAL_OPEN_RETRIES=3

# Si true (y API_IMAGES_GALLERY_ONLY=true), hotel sin fotos gallery_visible
# exporta images[] VACÍO. Default false = red de seguridad (envía superconjunto).
# Rango válido: true | false | Recomendado: false
API_IMAGES_STRICT_GALLERY=false


# ==============================================================================
# ── LANGUAGE CONFIGURATION — Single source of truth: languages.json (Build 98)
# ==============================================================================
# ENABLED_LANGUAGES define los idiomas de scraping.
# TODA la configuración de idioma (traducciones, mapeos, filtros) vive en
# el archivo indicado por LANGUAGES_CONFIG_FILE (default: languages.json).
# No hay hardcoding de idiomas en el código Python.
#
# PARA AÑADIR UN IDIOMA NUEVO (ej: "ru"):
#   1. Añadir "ru" a ENABLED_LANGUAGES
#   2. Abrir languages.json y añadir el código "ru" con sus valores en:
#      - lang_url_codes          (ej: "ru": "ru")
#      - lang_accept_headers     (ej: "ru": "ru-RU,ru;q=0.9")
#      - category_labels         (todos los api_keys con su etiqueta)
#      - see_all_patterns        (regex para filtrar "Ver todas" en ese idioma)
#   3. Reiniciar — el validador BLOQUEA el arranque si falta algo.
#
# Idiomas con soporte pre-configurado en languages.json:
#   Latino:   en, es, de, fr, it, pt, nl, pl, cs, sv, da, fi, nb
#   Cirílico: ru, uk
#   CJK:      zh, ja, ko
#   Árabe:    ar
#   Turco:    tr
# ==============================================================================

# Idiomas activos — 'en' siempre primero (se reordena automáticamente si se omite).
ENABLED_LANGUAGES=en,es,de,it,fr,pt

# Ruta al archivo JSON con todos los diccionarios de idioma.
LANGUAGES_CONFIG_FILE=languages.json


# ── Browser / Selenium ────────────────────────────────────────────────────────
# false → ventana Brave VISIBLE en escritorio (modo test/debug)
# true  → sin ventana (headless), modo producción
HEADLESS_BROWSER=false

BRAVE_PATH=C:\Program Files\BraveSoftware\Brave-Browser\Application\brave.exe

# BUG-CHROMEDRIVER-002-FIX (Build 119):
# CHROMEDRIVER_PATH comentado para activar webdriver-manager (Estrategia 2).
# Con esta línea activa, el sistema usa el binario estático → SessionNotCreatedException
# cada vez que Brave se auto-actualiza a una versión mayor nueva.
# Con esta línea comentada, _get_driver() en scraper.py detecta la versión instalada
# de Brave y descarga automáticamente el ChromeDriver compatible vía webdriver-manager.
# Solo descomentar para entornos offline o si necesitas fijar una versión específica.
# CHROMEDRIVER_PATH=C:\BookingScraper\drivers\chromedriver.exe


# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5


# ── Debug ─────────────────────────────────────────────────────────────────────
# DEBUG_HTML_SAVE=true guarda HTML crudo de páginas bloqueadas en data/debug_html/.
# Activar solo durante sesiones de diagnóstico.
DEBUG=false
DEBUG_HTML_SAVE=false
DEBUG_HTML_MAX_AGE_HOURS=24
