# ============================================================================
# .env.example — BookingScraper Pro v54
# Copia este archivo a .env y rellena tus valores.
# NUNCA subas .env al control de versiones.
# ============================================================================

# ── Seguridad (OBLIGATORIO) ───────────────────────────────────────────────────
# Genera con: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=REEMPLAZA_CON_CLAVE_ALEATORIA_DE_64_CARACTERES

# Proteccion de API (pon REQUIRE_API_KEY=true para activar)
API_KEY=
REQUIRE_API_KEY=false

# ── Base de datos (OBLIGATORIO) ───────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bookingscraper
DB_USER=bookingscraper_user
DB_PASSWORD=CAMBIA_ESTA_CONTRASENA_EN_PRODUCCION

# Pool de conexiones (Windows 11: max_connections=50 en postgresql.conf)
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=5
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# ── Redis / Memurai ───────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=20
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── Scraper ───────────────────────────────────────────────────────────────────
SCRAPER_MAX_WORKERS=2
SCRAPER_REQUEST_TIMEOUT=30
SCRAPER_RETRY_DELAY=2.0
MAX_RETRIES=3
MAX_LANG_RETRIES=3

# ── VPN (opcional — requiere NordVPN instalado) ───────────────────────────────
VPN_ENABLED=true
VPN_COUNTRIES=Spain,Germany,France,Netherlands,Italy,United_Kingdom,Canada,Sweden
VPN_ROTATION_INTERVAL=30

# ── Idiomas habilitados ───────────────────────────────────────────────────────
ENABLED_LANGUAGES=es,en,de,it

# ── Browser / Selenium ────────────────────────────────────────────────────────
# false → ventana Brave VISIBLE en escritorio (modo test/debug)
# true  → sin ventana, modo produccion
HEADLESS_BROWSER=false

# ── Rutas de datos (relativas al directorio del proyecto) ────────────────────
# Estructura real: logs/ y data/images/, data/exports/, data/logs/debug/
# Estas rutas se crean automaticamente — no es necesario configurarlas
# salvo que quieras cambiar las ubicaciones por defecto.
#
# LOGS_DIR=logs
# IMAGES_DIR=data/images
# EXPORT_DIR=data/exports
# DEBUG_HTML_DIR=data/logs/debug
# BACKUPS_DIR=backups

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# ── Debug (solo para desarrollo) ──────────────────────────────────────────────
DEBUG=false
DEBUG_HTML_SAVE=false
DEBUG_HTML_MAX_AGE_HOURS=24
