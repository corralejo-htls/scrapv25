# ============================================================================
# .env.example — BookingScraper Pro v6.0.0 Build 74
# APLICADO EN: C:\BookingScraper\.env
# Copia este archivo a .env y rellena tus valores.
# NUNCA subas .env al control de versiones.
#
# ── Historial de cambios en variables de configuración ───────────────────────
#
# BUILD 74: Simplificación — perfil Brave por defecto.
#   ⚠ SIN CAMBIOS EN VARIABLES.
#   Eliminado --user-data-dir=data/brave_profile. Brave usa su perfil normal.
#   SELENIUM_BRAVE_PROFILE_DIR="" (vacío = sin perfil aislado).
#   Resuelve DevToolsActivePort. Simplifica código. Comportamiento pre-Build 70.
#
# BUILD 73: BUG-BRAVE-001 + BUG-VPN-008-rev2 fixes (base de Build 74).
#   ⚠ SIN CAMBIOS EN VARIABLES — solo correcciones de código Python.
#   BUG-BRAVE-001: _prepare_fresh_profile() borra data/brave_profile completo
#                  antes de cada sesión Brave → resuelve 100% DevToolsActivePort.
#   BUG-VPN-008v2: popup NordVPN cierra via pywin32 (win32gui) en lugar de
#                  PowerShell P/Invoke que fallaba silenciosamente.
#
# BUILD 72: BUG-VPN-008 + BUG-SCRAPER-OS-001 fixes.
#   ⚠ SIN CAMBIOS EN VARIABLES — solo correcciones de código Python.
#   BUG-VPN-008:        popup «¿Pausar la conexión automática?» no se cerraba.
#                       UI Automation fallaba (ventana sin título).
#                       Fix: Win32 EnumChildWindows + BM_CLICK en botón «Cancelar».
#   BUG-SCRAPER-OS-001: NameError: os not defined en _clear_profile_singletons().
#                       Fix: import os movido al nivel de módulo en scraper.py.
#
# BUILD 71: BUG-VPN-004/005/006/007 fixes.
#   ⚠ SIN CAMBIOS EN VARIABLES — solo correcciones de código Python.
#   BUG-VPN-004: CREATE_NO_WINDOW → diálogo UAC DiagnosticsTool eliminado.
#   BUG-VPN-005: _dismiss_nordvpn_popup() + _close_nordaccount_browser_tabs()
#                → tabs nordaccount.com eliminados.
#   BUG-VPN-006: SELENIUM_BRAVE_PROFILE_DIR → perfil Brave aislado para Selenium.
#   BUG-VPN-007: _clear_profile_singletons() → resuelve 192 errores DevToolsActivePort.
#
# BUILD 70: NUEVA VARIABLE añadida.
#   SELENIUM_BRAVE_PROFILE_DIR  ← nueva (perfil Brave aislado para Selenium).
#
# BUILD 68: BUG-VPN-001 fix. VPN_ROTATION_INTERVAL comprobado por idioma.
#   ⚠ SIN CAMBIOS EN VARIABLES.
#
# BUILD 64: BUG-DATA-001 + BUG-PERF-001 fixes.
#   SELENIUM_CONTENT_WAIT_TIMEOUT_S  ← nueva.
#   LANG_SCRAPE_DELAY_IT             ← nueva.
#
# BUILD 63: cloudscraper eliminado. Selenium es el único motor de scraping.
#   ⚠ SIN CAMBIOS EN VARIABLES.
# ============================================================================

# ── Seguridad ─────────────────────────────────────────────────────────────────
# Para regenerar: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=generate_new_key
API_KEY=
REQUIRE_API_KEY=false

# ── Base de datos ─────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bookingscraper
DB_USER=bookingscraper_user_change
DB_PASSWORD=bookingscraper_user_key_change

# Pool de conexiones (Windows 11: max_connections=50 en postgresql.conf)
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=5
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# ── Redis / Memurai ───────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=20
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── Scraper — Build 63: parámetros ahora aplican a Selenium ──────────────────
SCRAPER_MAX_WORKERS=2
SCRAPER_REQUEST_TIMEOUT=30
# Build 63: SCRAPER_RETRY_DELAY ahora es el backoff de Selenium (era CloudScraper)
SCRAPER_RETRY_DELAY=2.0
MAX_RETRIES=3
# Build 63: MAX_LANG_RETRIES ahora es el retry de Selenium (era CloudScraper)
MAX_LANG_RETRIES=3

# ── BUG-LANG-001-FIX: Anti-bot detection / missing languages ─────────────────
# Delay base (segundos) entre idiomas consecutivos para el mismo URL.
# Simula lectura humana entre páginas. Reduce detección de bot por Booking.com.
# Rango válido: 0.0 - 120.0  |  Recomendado: 10.0
LANG_SCRAPE_DELAY=10.0

# Jitter aleatorio (0..N segundos) sumado al delay base.
# Evita patrones de request predecibles que activan rate-limiting.
# Rango válido: 0.0 - 30.0  |  Recomendado: 5.0
LANG_SCRAPE_JITTER=5.0

# Build 62: Reducido de 2 a 1 (VPN rota tras el PRIMER fallo).
# ip_known_blocked flag hace que esto sea efectivo desde el primer intento.
# Rango válido: 1 - 6 | Recomendado: 1
MAX_CONSECUTIVE_LANG_FAILURES=1

# Umbral en bytes para detectar páginas de bloqueo Cloudflare.
# Páginas reales de Booking.com miden 150.000-500.000 bytes.
# Una respuesta < SHORT_HTML_THRESHOLD es una challenge page → return None inmediato.
# Rango válido: 1000 - 20000  |  Recomendado: 5000
SHORT_HTML_THRESHOLD=5000

# ── BUG-PERF-001-FIX: Rendimiento idioma italiano (Build 64) ─────────────────
# Causa raíz: WebDriverWait con 4 selectores × 30 s = 120 s peor caso.
# Observado: it=144,0 s e it=124,6 s (ciclo 2026-04-01, 15,4% outliers).
#
# Tiempo de espera por selector CSS en el bucle de verificación de contenido.
# Con 4 selectores, peor caso = 4 × este valor.
# Antes usaba SCRAPER_REQUEST_TIMEOUT (30 s) → 120 s peor caso.
# Default 10 s → 40 s peor caso. Aumenta solo si las páginas cargan > 10 s.
# Rango válido: 2.0 - 60.0 | Recomendado: 10.0
SELENIUM_CONTENT_WAIT_TIMEOUT_S=10.0

# Delay adicional en segundos aplicado SOLO al pase del idioma italiano.
# Italian avg 73,7 s vs 49-64 s para otros idiomas (stddev 29,5 s).
# Espacia las peticiones italianas para reducir desafíos anti-bot acumulados.
# Rango válido: 0.0 - 60.0 | Recomendado: 5.0 | 0.0 para deshabilitar
LANG_SCRAPE_DELAY_IT=5.0

# ── BUG-LANG-002-FIX: Selenium language mismatch (Build 62) ──────────────────
# Inyectar Accept-Language correcto vía CDP y borrar cookies antes de cada
# carga de página en Selenium. Previene que bkng_lang cookie sobrescriba ?lang=.
SELENIUM_RESET_LANG_ON_EACH_REQUEST=true

# Reiniciar el browser Selenium completo tras cada rotación forzada de VPN.
# Garantiza perfil limpio: sin DNS cacheado, sin sesiones TLS reusadas.
SELENIUM_RESTART_AFTER_VPN_ROTATE=true

# Segundos de espera para verificar el idioma de la página tras carga.
SELENIUM_LANG_VERIFY_TIMEOUT_S=5.0

# ── BUG-VPN-006-FIX: Perfil Brave aislado para Selenium (Build 70) ───────────
# NordVPN abre el navegador predeterminado del sistema (Brave, perfil por defecto)
# para OAuth o páginas de soporte. Sin este parámetro, ambas instancias de Brave
# comparten el mismo perfil → los tabs de nordaccount.com aparecen dentro de la
# sesión de Selenium.
#
# Con este directorio, Selenium usa un perfil completamente distinto al del sistema
# → NordVPN abre una instancia Brave separada con su propio perfil → cero
# interferencias con el scraping.
#
# El directorio se crea automáticamente si no existe.
#
# ── BUG-VPN-007-FIX: SingletonLock cleanup (Build 71) ───────────────────────
# Cuando reset_browser() mata Brave tras una rotación VPN, Chromium deja
# archivos SingletonLock/SingletonSocket/SingletonCookie en este directorio.
# En el siguiente intento, Brave detecta una "instancia activa" y sale
# inmediatamente → DevToolsActivePort no existe → SessionNotCreatedException.
# Solución: _clear_profile_singletons() en scraper.py elimina estos archivos
# antes de cada nueva sesión WebDriver. No requiere cambio de configuración.
# Dejar en blanco "" para deshabilitar (Selenium usará el perfil del sistema).
# Ruta relativa al directorio del proyecto (C:\BookingScraper).
# Recomendado: data/brave_profile
# BUILD 74: deshabilitado — Brave usa su perfil del sistema (comportamiento original)
# SELENIUM_BRAVE_PROFILE_DIR=

# ── VPN — NordVPN v7.57.4.0 ───────────────────────────────────────────────────
VPN_ENABLED=true
VPN_COUNTRIES=Spain,Germany,France,Netherlands,Italy,United_Kingdom,Canada,Sweden

# Rotar IP cada 50 segundos para evitar bloqueos.
# BUILD 68 — BUG-VPN-001-FIX: comprobado antes de CADA idioma (no solo en
# batch start). Adicionalmente, cualquier error de fetch dispara rotación
# inmediata con force=True independientemente del tiempo transcurrido.
VPN_ROTATION_INTERVAL=50

# ── Idiomas habilitados ───────────────────────────────────────────────────────
# Regla: 'en' siempre se scrapeará primero aunque no esté en esta lista.
# Si 'en' no está incluido, se añade automáticamente como primer idioma.
ENABLED_LANGUAGES=en,es,de,it,fr,pt

# ── Browser / Selenium ────────────────────────────────────────────────────────
# false → ventana Brave VISIBLE en escritorio (modo test/debug)
# true  → sin ventana, modo produccion
HEADLESS_BROWSER=false

# Rutas opcionales (si no se definen, usa PATH del sistema)
# BRAVE_PATH=C:\Program Files\BraveSoftware\Brave-Browser\Application\brave.exe
# CHROMEDRIVER_PATH=C:\chromedriver\chromedriver.exe
BRAVE_PATH=C:\Program Files\BraveSoftware\Brave-Browser\Application\brave.exe
CHROMEDRIVER_PATH=C:\BookingScraper\drivers\chromedriver.exe

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# ── Debug ─────────────────────────────────────────────────────────────────────
DEBUG=false
DEBUG_HTML_SAVE=false
DEBUG_HTML_MAX_AGE_HOURS=24
